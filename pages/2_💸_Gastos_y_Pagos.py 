import streamlit as st
import pandas as pd
from database import supabase
from logic import formatear_moneda

st.set_page_config(page_title="Historial de Gastos", page_icon="💸", layout="wide")

st.title("💸 Historial de Gastos y Pagos")

# --- CARGAR DATOS ---
@st.cache_data(ttl=30)
def obtener_todos_los_pagos():
    # Traemos los pagos y los unimos con la fecha del cierre
    response = supabase.table("pagos").select("*, cierres(fecha)").execute()
    return pd.DataFrame(response.data)

df_pagos = obtener_todos_los_pagos()

if df_pagos.empty:
    st.info("No hay pagos registrados aún.")
else:
    # Aplanar la columna de fecha que viene del join de Supabase
    df_pagos['fecha'] = df_pagos['cierres'].apply(lambda x: x['fecha'] if x else "Sin fecha")
    
    # --- FILTROS ---
    col1, col2 = st.columns(2)
    with col1:
        busqueda = st.text_input("🔍 Buscar por concepto (ej: Gaseosas, Maritza...)", "")
    with col2:
        metodo_filtro = st.multiselect("Filtrar por método:", ["Efectivo", "Nequi"], default=["Efectivo", "Nequi"])

    # Aplicar filtros
    mask = df_pagos['concepto'].str.contains(busqueda, case=False) & df_pagos['metodo_pago'].isin(metodo_filtro)
    df_filtrado = df_pagos[mask].copy()

    # --- TABLA DE RESULTADOS ---
    st.subheader("Listado de Egresos")
    
    # Formatear para mostrar
    df_display = df_filtrado[['fecha', 'concepto', 'valor', 'metodo_pago']].sort_values(by="fecha", ascending=False)
    
    st.dataframe(
        df_display, 
        column_config={
            "fecha": "Fecha",
            "concepto": "Concepto / Proveedor",
            "valor": st.column_config.NumberColumn("Monto", format="$ %d"),
            "metodo_pago": "Pagado con"
        },
        use_container_width=True,
        hide_index=True
    )

    # --- RESUMEN DE GASTOS ---
    st.divider()
    total_filtrado = df_filtrado['valor'].sum()
    st.metric("Total Gastado en Selección", formatear_moneda(total_filtrado))

    # --- EXPORTAR ---
    csv = df_display.to_csv(index=False).encode('utf-8')
    st.download_button(
        label="📥 Descargar Reporte de Gastos (CSV)",
        data=csv,
        file_name='gastos_cafeteria.csv',
        mime='text/csv',
    )